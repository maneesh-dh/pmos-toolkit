# adr-cap — ADR write capped at 5/run; overflow surfaces under adrs_truncated[].
# Setup: fixture stages 12 secret-bearing files (U009 block); audit must
# produce 12 findings, write at most 5 ADRs, and truncate the rest.
set -euo pipefail
# Reset any previously-written ADRs from earlier runs so the cap is exercised fresh.
rm -rf docs/adrs docs/adr 2>/dev/null || true
out=$($AUDIT) || { echo "audit exited non-zero"; exit 1; }
findings=$(echo "$out" | jq '.findings | length')
written=$(echo "$out" | jq '.adrs_written // [] | length')
truncated=$(echo "$out" | jq '.adrs_truncated // [] | length')
[ "$findings" -ge 6 ] || { echo "expected ≥6 findings to exercise cap; got $findings"; exit 1; }
[ "$written" -le 5 ]  || { echo "ADR write cap (5) breached: written=$written"; exit 1; }
[ "$truncated" -ge 1 ] || { echo "expected adrs_truncated[] to surface overflow; truncated=$truncated"; exit 1; }

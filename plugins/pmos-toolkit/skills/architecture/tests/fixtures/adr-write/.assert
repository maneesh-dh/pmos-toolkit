# adr-write — a block-severity finding promotes to an ADR file written via Nygard (FR-60/61/62).
set -euo pipefail
rm -rf docs/adrs docs/adr 2>/dev/null || true
out=$($AUDIT) || { echo "audit exited non-zero"; exit 1; }
written=$(echo "$out" | jq '.adrs_written | length')
[ "$written" -ge 1 ] || { echo "expected ≥1 ADR written; got $written"; exit 1; }
echo "$out" | jq -e '.adrs_written[0].path | test("docs/adrs?/ADR-[0-9]{4}-.+\\.md$")' >/dev/null \
  || { echo "ADR path doesn't match docs/adr(s)/ADR-NNNN-<slug>.md"; echo "$out" | jq '.adrs_written[0]'; exit 1; }
echo "$out" | jq -e '.adrs_written[0].nnnn | test("^[0-9]{4}$")' >/dev/null \
  || { echo "ADR nnnn must be zero-padded 4 digits"; exit 1; }

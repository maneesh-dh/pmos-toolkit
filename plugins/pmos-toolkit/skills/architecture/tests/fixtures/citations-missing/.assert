# citations-missing — fixture is consumed by tools/check-citations.sh, not run-audit.sh.
# Assertion: the gate refuses this principles.yaml with exit 1 and surfaces U001 as
# the offender (FR-24).
set -euo pipefail
set +e
err=$(bash "$SKILL_DIR/tools/check-citations.sh" ./principles.yaml 2>&1 >/dev/null)
ec=$?
set -e
[ "$ec" -eq 1 ] || { echo "expected check-citations exit=1; got $ec"; exit 1; }
echo "$err" | grep -q "U001" || { echo "expected U001 in offender list; got: $err"; exit 1; }

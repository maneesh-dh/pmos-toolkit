# l3-malformed — a syntactically broken L3 principles.yaml must be rejected
# with a usage-level exit code (64), not silently ignored.
set -euo pipefail
set +e
$AUDIT >/dev/null 2>&1
ec=$?
set -e
# The audit harness should refuse malformed YAML with a non-zero exit; the canonical
# usage exit is 64. (FR-14 / D14 — never silently degrade on malformed config.)
[ "$ec" -ne 0 ] || { echo "expected non-zero exit on malformed L3; got 0"; exit 1; }
